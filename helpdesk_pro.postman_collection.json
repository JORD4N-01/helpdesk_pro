                  "  pm.expect(json).to.have.property('total_chamados');",
                  "  pm.expect(json).to.have.property('em_atraso');",
                  "  pm.expect(json).to.have.property('tecnicos_disponiveis');",
                  "  pm.expect(json).to.have.property('top3_clientes');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Erros (testes negativos)",
      "item": [
