          "name": "Campo obrigatório ausente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/chamados",
              "host": ["{{base_url}}"],
              "path": ["chamados"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Mensagem de erro', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('erro');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Prioridade inválida",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Teste\",\n  \"descricao\": \"Teste\",\n  \"cliente\": \"Teste\",\n  \"prioridade\": \"urgente\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chamados",
              "host": ["{{base_url}}"],
              "path": ["chamados"]
            }
          },
          "event": [
            {
              "listen": "test",
