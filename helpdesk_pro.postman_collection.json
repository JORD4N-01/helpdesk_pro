          ]
        },
        {
          "name": "Transição de status inválida",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"novo_status\": \"fechado\",\n  \"responsavel\": \"Jordan\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chamados/1/status",
              "host": ["{{base_url}}"],
              "path": ["chamados", "1", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Erro de transicao', () => {",
                  "  pm.expect(pm.response.json().erro).to.include('Transicao invalida');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Chamado não encontrado (404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/chamados/999",
              "host": ["{{base_url}}"],
              "path": ["chamados", "999"]
